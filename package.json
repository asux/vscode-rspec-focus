{
  "name": "rspec-focus",
  "displayName": "RSpec Focus",
  "description": "Add and clear focus mode in RSpec files",
  "version": "0.4.0",
  "license": "MIT",
  "publisher": "asux",
  "icon": "rspec.png",
  "galleryBanner": {
    "color": "#232323",
    "theme": "dark"
  },
  "author": {
    "name": "Oleksandr Ulianytskyi",
    "email": "a.ulyanitsky@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/asux/vscode-rspec-focus.git"
  },
  "bugs": {
    "url": "https://github.com/asux/vscode-rspec-focus/issues"
  },
  "homepage": "https://github.com/asux/vscode-rspec-focus",
  "categories": [
    "Other"
  ],
  "keywords": [
    "ruby",
    "rspec",
    "focus"
  ],
  "activationEvents": [
    "onLanguage:ruby"
  ],
  "main": "./out/src/extension",
  "contributes": {
    "configuration": {
      "title": "RSpec Focus",
      "properties": {
        "rspec-focus.focusTag": {
          "type": "string",
          "default": "focus",
          "description": "RSpec tag used for focus (e.g. focus, wip). Inserted as :tag in examples."
        }
      }
    },
    "commands": [
      {
        "command": "rspec-focus.add",
        "title": "RSpec Focus: Add"
      },
      {
        "command": "rspec-focus.clear",
        "title": "RSpec Focus: Clear"
      }
    ],
    "keybindings": [
      {
        "command": "rspec-focus.add",
        "key": "ctrl-alt-cmd-t",
        "when": "editorTextFocus"
      },
      {
        "command": "rspec-focus.clear",
        "key": "ctrl-alt-cmd-z",
        "when": "editorTextFocus"
      }
    ]
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "overrides": {
    "diff": ">=8.0.3",
    "serialize-javascript": ">=7.0.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^4.5.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
